{
    "name": "369work/misleading-checker",
    "description": "薬機法・景品表示法のNG表現を検出するPHPライブラリ。記事やLPの入稿前チェック、納品前の品質管理に。",
    "type": "library",
    "keywords": [
    	"yakki",
    	"薬機法",
    	"景品表示法",
    	"compliance",
    	"ng-word",
    	"misleading",
    	"checker",
    	"php"
    ],
    "license": "GPL-3.0-or-later",
    "require": {
        "php": ">=8.1",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Yakki\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Yakki\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
